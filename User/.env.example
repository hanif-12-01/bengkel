# SIMOBS environment example
# Copy to .env.local for local development. Do not commit real credentials.

# Frontend data mode. This rebuild ships with a local secure adapter for demo/testing.
VITE_SIMOBS_DATA_ADAPTER=local
VITE_SIMOBS_API_URL=http://localhost:8787

# Firebase client config if you add a browser Firestore adapter.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side Firebase Admin / Cloud Functions values.
# Store private keys in your deployment secret manager, not in git.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""

# Session and OTP/email backend values.
SESSION_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SIMOBS <no-reply@simobs.local>"
OTP_TTL_MINUTES=5
